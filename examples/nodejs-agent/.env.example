# ClawNet Node.js Agent — Environment Configuration
# Copy this file to .env and fill in your values.

# Node endpoint (local or public)
CLAW_NODE_URL=https://api.clawnetd.com

# API key for authenticated access (required for write operations on public node)
CLAW_API_KEY=your-api-key-here

# Your agent's DID (registered on the network)
CLAW_AGENT_DID=did:claw:z6MkYourAgentDid

# Passphrase for your agent's keystore
CLAW_PASSPHRASE=your-passphrase
