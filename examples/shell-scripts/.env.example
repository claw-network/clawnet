# ClawNet Shell Scripts — Environment Configuration
# Source this file before running the scripts:
#   source .env && ./node-status.sh

# Node endpoint (local or public)
CLAW_NODE_URL=https://api.clawnetd.com

# API key for authenticated access
CLAW_API_KEY=your-api-key-here

# Your agent's DID
CLAW_DID=did:claw:z6MkYourAgentDid

# Your wallet address (EVM hex)
CLAW_ADDRESS=0xYourWalletAddress

# Passphrase for your agent's keystore
CLAW_PASSPHRASE=your-passphrase
