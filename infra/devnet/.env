# ============================================================
# ClawNet Local Devnet — Environment Variables
# ============================================================
# geth --dev mode: chainId = 1337, auto-mining, pre-funded dev account

# Devnet chain
CLAWNET_DEVNET_CHAIN_ID=1337
CLAWNET_DEVNET_RPC_URL=http://127.0.0.1:8545

# Deployer = Hardhat default account #0 (no secrets needed for local dev)
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
DEPLOYER_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266

# Geth data directory (relative to infra/devnet/)
GETH_DATADIR=./data

# Geth dev settings
GETH_DEV_PERIOD=0
GETH_DEV_GASLIMIT=30000000

# HTTP RPC
GETH_HTTP_PORT=8545

# Emergency signers — 9 deterministic dev addresses (DO NOT use in production)
# These are Hardhat default accounts #1 through #9
EMERGENCY_SIGNERS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8,0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC,0x90F79bf6EB2c4f870365E785982E1f101E93b906,0x15d34AAf54267DB7D7c367839AAf71A00a2C6A65,0x9965507D1a55bcC2695C58ba16FB37d819B0A4dc,0x976EA74026E726554dB657fA54763abd0C3a0aa9,0x14dc79964dA2C08DaA4968306558C02D9970e84F,0x23618e81E3f5cdF7f54C3d65f7FBc0aBf5B21E8f,0xa0Ee7A142d267C1f36714E4a8F75612F20a79720
