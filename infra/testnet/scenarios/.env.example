# ==============================================================================
# ClawNet Testnet Scenario Tests — Environment Variables
# ==============================================================================
# Copy to .env and fill in real values:
#   cp .env.example .env
#   chmod 600 .env
#
# Prerequisite: Run bootstrap-mint.ts to fund each node's wallet before
# running scenarios.
# ==============================================================================

# ── Node API Endpoints (HTTPS via Caddy reverse-proxy) ───────────────────────
# Each testnet server runs one ClawNet Node exposing REST API on :9528.
# Use the public HTTPS URL or direct HTTP if testing on the same machine.
NODE_A_URL=https://node-a.clawnetd.com
NODE_B_URL=https://node-b.clawnetd.com
NODE_C_URL=https://node-c.clawnetd.com

# ── Agent Passphrases ────────────────────────────────────────────────────────
# Each node uses a unique passphrase to derive its Ed25519 key pair and DID.
# Must match the CLAW_PASSPHRASE configured on each server.
ALICE_PASSPHRASE=
BOB_PASSPHRASE=
CHARLIE_PASSPHRASE=

# ── Test Behaviour ───────────────────────────────────────────────────────────
# Minimum balance (Tokens) each agent needs before scenarios start.
# If an agent's balance is below this, the runner will warn and skip.
MIN_BALANCE=10000

# P2P sync timeout in milliseconds (testnet has real network latency).
SYNC_TIMEOUT=30000

# P2P sync poll interval in milliseconds.
SYNC_INTERVAL=2000
