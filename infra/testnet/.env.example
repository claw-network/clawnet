# ==============================================================================
# ClawNet Chain — Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in real values before starting services.
#   cp .env.example .env
#   chmod 600 .env
#
# WARNING: Never commit .env to version control!
# ==============================================================================

# ── Network Identity ─────────────────────────────────────────────────────────
# Chain ID (固定值, do NOT change)
CHAIN_ID=7625

# ── Geth Validator Configuration ─────────────────────────────────────────────
# Address of this node's validator account (with 0x prefix)
# This address must match the account imported into chain-data/keystore/
VALIDATOR_ADDRESS=

# ── Contract Deployment (Server A only) ──────────────────────────────────────
# Deployer private key (with 0x prefix)
DEPLOYER_PRIVATE_KEY=

# Treasury address (receives protocol fees)
TREASURY_ADDRESS=

# Dedicated liquidity wallet (MUST be different from TREASURY_ADDRESS)
LIQUIDITY_ADDRESS=

# Dedicated risk reserve wallet (MUST be different from TREASURY_ADDRESS and LIQUIDITY_ADDRESS)
RESERVE_ADDRESS=

# RPC URL for contract deployment (use localhost on Server A)
CLAWNET_RPC_URL=http://127.0.0.1:8545

# ── ClawNet Node (clawnetd) ──────────────────────────────────────────────────
# Passphrase for encrypting node identity key
CLAW_PASSPHRASE=

# API key for authenticated REST endpoints (hex string)
CLAW_API_KEY=

# Private key for on-chain interaction (EventIndexer, contract calls)
CLAW_PRIVATE_KEY=0x...

# Emergency DAO signers (9 unique addresses, comma-separated)
EMERGENCY_SIGNERS=

# ── Monitoring & Logging ─────────────────────────────────────────────────────
# Log level: trace, debug, info, warn, error
LOG_LEVEL=info

# Alert webhook URL (Feishu / DingTalk / Slack)
# Leave empty to disable alerting
ALERT_WEBHOOK_URL=

# ── Security Audit Email ─────────────────────────────────────────────────────
# SMTP credentials for security-audit.sh email reports
# Default sender: security-audit@clawnetd.com via mail.clawnetd.com:465 (SMTPS)
CLAWNET_SMTP_USER=security-audit@clawnetd.com
CLAWNET_SMTP_PASS=

# Report recipient (default: noreply@clawnetd.com)
CLAWNET_REPORT_EMAIL=noreply@clawnetd.com

# Send email even when all checks pass (default: false — only on issues)
CLAWNET_EMAIL_ON_SUCCESS=false

# ── SSH Access ────────────────────────────────────────────────────────────────
# Admin SSH public key (used by setup-server.sh Step 10 to harden SSH)
# After setup, password login is disabled — only this key can access the server.
# Generate with: ssh-keygen -t ed25519 -C "clawnet-server-admin" -f ~/.ssh/id_ed25519_clawnet
ADMIN_SSH_PUBKEY=ssh-ed25519 AAAA...

# ── Backup (Optional) ────────────────────────────────────────────────────────
# Remote backup target (rsync format, e.g., user@backup-host:/backups/clawnet)
BACKUP_TARGET=

# Backup schedule (cron expression, default: daily 3am UTC)
BACKUP_CRON=0 3 * * *
