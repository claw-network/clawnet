# ClawNet — Server A Caddyfile (Homepage + API + RPC)
# ==============================================================================
# Location: /etc/caddy/Caddyfile on Server A (66.94.125.242)
#
# Install: cp infra/chain-testnet/Caddyfile /etc/caddy/Caddyfile
#          systemctl restart caddy
# ==============================================================================

# ── Homepage ─────────────────────────────────────────────────────────────────
clawnetd.com {
    # install.sh served from /var/www/clawnetd
    handle /install.sh {
        root * /var/www/clawnetd
        header Content-Type "text/x-shellscript; charset=utf-8"
        file_server
    }

    # Everything else: SPA from the homepage dist
    handle {
        root * /opt/clawnet/packages/homepage/dist
        try_files {path} /index.html
        file_server

        header {
            Strict-Transport-Security "max-age=63072000; includeSubDomains"
            X-Content-Type-Options    nosniff
            X-Frame-Options           SAMEORIGIN
            Referrer-Policy           strict-origin-when-cross-origin
            -Server
        }
    }

    log {
        output file /var/log/caddy/homepage-access.log {
            roll_size 50mb
            roll_keep 5
        }
    }
}

# ── clawnetd REST API ────────────────────────────────────────────────────────
api.clawnetd.com {
    @write_ops {
        method POST PUT DELETE PATCH
        not header X-API-Key {env.CLAW_API_KEY}
    }
    respond @write_ops 401 {
        body "Unauthorized: X-API-Key required"
        close
    }

    reverse_proxy localhost:9528 {
        transport http {
            read_timeout  30s
            write_timeout 30s
        }
    }

    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains"
        X-Content-Type-Options    nosniff
        X-Frame-Options           DENY
        Referrer-Policy           no-referrer
        -Server
    }

    log {
        output file /var/log/caddy/api-access.log {
            roll_size 50mb
            roll_keep 5
        }
    }
}

# ── Chain JSON-RPC ───────────────────────────────────────────────────────────
rpc.clawnetd.com {
    @not_post not method POST
    respond @not_post 405 {
        body "Method Not Allowed: JSON-RPC requires POST"
        close
    }

    # NOTE: body_regexp is NOT available in Caddy v2.11.x
    # Dangerous RPC method filtering must be done at Geth --http.api level

    reverse_proxy localhost:8545 {
        transport http {
            read_timeout  30s
            write_timeout 30s
        }
    }

    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains"
        X-Content-Type-Options    nosniff
        Access-Control-Allow-Origin "*"
        Access-Control-Allow-Methods "POST, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, X-API-Key"
        -Server
    }

    log {
        output file /var/log/caddy/rpc-access.log {
            roll_size 50mb
            roll_keep 5
        }
    }
}

# ── Documentation Site ───────────────────────────────────────────────────────
docs.clawnetd.com {
    reverse_proxy localhost:3001 {
        transport http {
            read_timeout  30s
            write_timeout 30s
        }
    }

    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains"
        X-Content-Type-Options    nosniff
        X-Frame-Options           SAMEORIGIN
        Referrer-Policy           strict-origin-when-cross-origin
        -Server
    }

    log {
        output file /var/log/caddy/docs-access.log {
            roll_size 50mb
            roll_keep 5
        }
    }
}

# ── Wallet Web App ───────────────────────────────────────────────────────────
wallet.clawnetd.com {
    root * /opt/clawnet/packages/wallet/dist
    try_files {path} /index.html
    file_server

    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains"
        X-Content-Type-Options    nosniff
        X-Frame-Options           SAMEORIGIN
        Referrer-Policy           strict-origin-when-cross-origin
        -Server
    }

    log {
        output file /var/log/caddy/wallet-access.log {
            roll_size 50mb
            roll_keep 5
        }
    }
}
