# ==============================================================================
# ClawNet Mainnet — Environment Variables
# ==============================================================================
# Copy to .env and fill in real values:
#   cp .env.example .env
#   chmod 600 .env
# ==============================================================================

# ── Geth Validator ───────────────────────────────────────────────────────────
VALIDATOR_ADDRESS=0x...

# ── Bootnodes (for peer validators, comma-separated enode URLs) ──────────────
BOOTNODES=enode://...@<node1-ip>:30303

# ── Caddy RPC API Key ────────────────────────────────────────────────────────
RPC_API_KEY=

# ── Chain Configuration ──────────────────────────────────────────────────────
CHAIN_ID=7626
NETWORK_ID=7626

# ── ClawNet Node (clawnetd) ──────────────────────────────────────────────────
CLAW_PASSPHRASE=
CLAW_DATA_DIR=/opt/clawnet/data
CLAW_P2P_PORT=9527
CLAW_API_PORT=9528
CLAW_CHAIN_RPC_URL=http://127.0.0.1:8545
CLAW_CHAIN_CONTRACTS_FILE=/opt/clawnet/config/clawnetMainnet.json

# ── Contract Deployment ──────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x...
CLAWNET_RPC_URL=http://127.0.0.1:8545
TREASURY_ADDRESS=0x...

# Dedicated liquidity wallet (MUST be different from TREASURY_ADDRESS)
LIQUIDITY_ADDRESS=0x...

# Dedicated risk reserve wallet (MUST be different from TREASURY_ADDRESS and LIQUIDITY_ADDRESS)
RESERVE_ADDRESS=0x...

# Emergency DAO signers (9 unique addresses, comma-separated)
EMERGENCY_SIGNERS=

# ── Monitoring & Logging ─────────────────────────────────────────────────────
# Log level: trace, debug, info, warn, error
LOG_LEVEL=info

# Alert webhook URL (Feishu / DingTalk / Slack)
# Leave empty to disable alerting
ALERT_WEBHOOK_URL=

# ── Backup (Optional) ────────────────────────────────────────────────────────
# Remote backup target (rsync format, e.g., user@backup-host:/backups/clawnet)
BACKUP_TARGET=
