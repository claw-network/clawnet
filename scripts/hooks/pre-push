#!/bin/bash
#
# pre-push hook вЂ” block push unless build + tests pass
#
# Skip:  git push --no-verify
#        SKIP_TESTS=1 git push
#

# в”Ђв”Ђ allow skipping в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if [ "${SKIP_TESTS:-0}" = "1" ]; then
  echo "вљ пёЏ  SKIP_TESTS=1 вЂ” skipping pre-push tests"
  exit 0
fi

# в”Ђв”Ђ colours (disabled when not a tty) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if [ -t 1 ]; then
  BOLD="\033[1m"
  DIM="\033[2m"
  RED="\033[31m"
  GREEN="\033[32m"
  YELLOW="\033[33m"
  CYAN="\033[36m"
  RESET="\033[0m"
else
  BOLD="" DIM="" RED="" GREEN="" YELLOW="" CYAN="" RESET=""
fi

# в”Ђв”Ђ package list (keep in dependency order) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
PACKAGES=(
  "core"
  "protocol"
  "contracts"
  "node"
  "sdk"
  "cli"
)

TOTAL=${#PACKAGES[@]}
PASSED=0
FAILED=0
FAILED_NAMES=""
TOTAL_START=$(date +%s)

# в”Ђв”Ђ banner в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo ""
echo -e "${BOLD}рџ”’ Pre-push: lint + build + test + contracts + integration${RESET}"
echo -e "${DIM}   Skip with: git push --no-verify${RESET}"
echo -e "${DIM}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${RESET}"

# в”Ђв”Ђ phase 1: lint в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo -e "${BOLD}рџ”Ќ Phase 1/4 вЂ” Lint${RESET}"
LINT_START=$(date +%s)
LINT_LOG=$(mktemp)

printf "  %-28s " "pnpm lint"

pnpm lint > "$LINT_LOG" 2>&1
LINT_EC=$?
LINT_END=$(date +%s)
LINT_SECS=$((LINT_END - LINT_START))

if [ $LINT_EC -eq 0 ]; then
  echo -e "${GREEN}вњ… passed${RESET} ${DIM}(${LINT_SECS}s)${RESET}"
else
  echo -e "${RED}вќЊ LINT FAILED${RESET} ${DIM}(${LINT_SECS}s)${RESET}"
  echo -e "${DIM}в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€${RESET}"
  tail -40 "$LINT_LOG" | sed 's/^/    /'
  echo -e "${DIM}в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€${RESET}"
  rm -f "$LINT_LOG"
  echo -e "${DIM}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${RESET}"
  echo -e "${RED}${BOLD}вќЊ Lint failed${RESET}"
  echo -e "   Push aborted. Fix lint errors and try again."
  echo ""
  exit 1
fi
rm -f "$LINT_LOG"
echo ""

# в”Ђв”Ђ phase 2: build в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
BUILD_FAILED=0
BUILD_FAILED_NAMES=""
echo -e "${BOLD}рџ“¦ Phase 2/4 вЂ” Build${RESET}"

BUILD_IDX=0
for PKG in "${PACKAGES[@]}"; do
  BUILD_IDX=$((BUILD_IDX + 1))
  FILTER="@claw-network/${PKG}"
  BUILD_START=$(date +%s)

  printf "  ${DIM}[%d/%d]${RESET} %-28s " "$BUILD_IDX" "$TOTAL" "$FILTER"

  BUILD_LOG=$(mktemp)

  # contracts uses "compile" (hardhat); others use "build" (tsc)
  if [ "$PKG" = "contracts" ]; then
    BUILD_CMD="compile"
  else
    BUILD_CMD="build"
  fi

  pnpm --filter "$FILTER" "$BUILD_CMD" > "$BUILD_LOG" 2>&1
  BUILD_EC=$?
  BUILD_END=$(date +%s)
  BUILD_SECS=$((BUILD_END - BUILD_START))

  if [ $BUILD_EC -eq 0 ]; then
    echo -e "${GREEN}вњ… built${RESET} ${DIM}(${BUILD_SECS}s)${RESET}"
  else
    BUILD_FAILED=$((BUILD_FAILED + 1))
    BUILD_FAILED_NAMES="${BUILD_FAILED_NAMES}  вЂў ${FILTER}\n"
    echo -e "${RED}вќЊ BUILD FAILED${RESET} ${DIM}(${BUILD_SECS}s)${RESET}"
    echo -e "${DIM}в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€${RESET}"
    tail -30 "$BUILD_LOG" | sed 's/^/    /'
    echo -e "${DIM}в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€${RESET}"
  fi
  rm -f "$BUILD_LOG"
done

if [ $BUILD_FAILED -gt 0 ]; then
  TOTAL_END=$(date +%s)
  TOTAL_SECS=$((TOTAL_END - TOTAL_START))
  echo -e "${DIM}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${RESET}"
  echo -e "${RED}${BOLD}вќЊ ${BUILD_FAILED} package(s) failed to build${RESET} ${DIM}(${TOTAL_SECS}s total)${RESET}"
  echo -e "${RED}${BUILD_FAILED_NAMES}${RESET}"
  echo -e "   Push aborted. Fix the build errors and try again."
  echo ""
  exit 1
fi

echo ""

# в”Ђв”Ђ phase 3: test в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo -e "${BOLD}рџ§Є Phase 3/4 вЂ” Test${RESET}"
IDX=0
for PKG in "${PACKAGES[@]}"; do
  IDX=$((IDX + 1))
  FILTER="@claw-network/${PKG}"
  PKG_START=$(date +%s)

  # Print progress header (no newline вЂ” will append result)
  printf "  ${DIM}[%d/%d]${RESET} %-28s " "$IDX" "$TOTAL" "$FILTER"

  # Run test, capture output and exit code
  LOG=$(mktemp)
  pnpm --filter "$FILTER" test > "$LOG" 2>&1
  EC=$?
  PKG_END=$(date +%s)
  PKG_SECS=$((PKG_END - PKG_START))

  if [ $EC -eq 0 ]; then
    PASSED=$((PASSED + 1))
    echo -e "${GREEN}вњ… passed${RESET} ${DIM}(${PKG_SECS}s)${RESET}"
  else
    FAILED=$((FAILED + 1))
    FAILED_NAMES="${FAILED_NAMES}  вЂў ${FILTER}\n"
    echo -e "${RED}вќЊ FAILED${RESET} ${DIM}(${PKG_SECS}s)${RESET}"
    # Show last 30 lines of failed output for diagnosis
    echo -e "${DIM}в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€${RESET}"
    tail -30 "$LOG" | sed 's/^/    /'
    echo -e "${DIM}в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€${RESET}"
  fi
  rm -f "$LOG"
done

# в”Ђв”Ђ summary в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
TOTAL_END=$(date +%s)
TOTAL_SECS=$((TOTAL_END - TOTAL_START))
echo -e "${DIM}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${RESET}"

if [ $FAILED -gt 0 ]; then
  echo -e "${RED}${BOLD}вќЊ ${FAILED} package(s) failed tests${RESET} ${DIM}(${TOTAL_SECS}s total)${RESET}"
  echo -e "${RED}${FAILED_NAMES}${RESET}"
  echo -e "   Push aborted. Fix the failing tests and try again."
  echo ""
  exit 1
fi

echo ""

# в”Ђв”Ђ phase 4: integration test в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo -e "${BOLD}рџЊђ Phase 4/4 вЂ” Integration Test${RESET}"
INT_START=$(date +%s)
INT_LOG=$(mktemp)

printf "  %-28s " "integration-test.mjs"

node scripts/integration-test.mjs > "$INT_LOG" 2>&1
INT_EC=$?
INT_END=$(date +%s)
INT_SECS=$((INT_END - INT_START))

if [ $INT_EC -eq 0 ]; then
  echo -e "${GREEN}вњ… passed${RESET} ${DIM}(${INT_SECS}s)${RESET}"
else
  echo -e "${YELLOW}вљ пёЏ  FAILED (non-blocking)${RESET} ${DIM}(${INT_SECS}s)${RESET}"
  echo -e "${DIM}в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€${RESET}"
  tail -20 "$INT_LOG" | sed 's/^/    /'
  echo -e "${DIM}в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€в”€${RESET}"
  echo -e "${YELLOW}   Integration tests failed but push continues (testnet may not be running).${RESET}"
fi
rm -f "$INT_LOG"

# в”Ђв”Ђ summary в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
TOTAL_END=$(date +%s)
TOTAL_SECS=$((TOTAL_END - TOTAL_START))
echo -e "${DIM}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${RESET}"
echo -e "${GREEN}${BOLD}вњ… Lint + build + test: all ${PASSED} packages passed${RESET} ${DIM}(${TOTAL_SECS}s total)${RESET}"
echo -e "   Pushing..."
echo ""
exit 0
