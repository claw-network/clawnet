# cron template for liquidity bot
# Install with: crontab -e
#
# Adjust LIQUIDITY_BOT_ENV_FILE to your local env file path.
# Runtime logs are written into scripts/liquidity-bot/logs/.
# Aggregated report files are written into LIQUIDITY_REPORT_STORE_DIR.

SHELL=/bin/bash
PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin

LIQUIDITY_BOT_ENV_FILE=/Users/yourname/workspace/private-repo/Bots/clawnet/scripts/liquidity-bot/schedule.env

# Run every hour at minute 10
10 * * * * /bin/bash -lc 'source "$LIQUIDITY_BOT_ENV_FILE" && "$ROOT/scripts/liquidity-bot/run/run-scheduled.sh" --count 1 --cycles 2'

# Run reserve daily incident report every day at 00:20 (local time)
20 0 * * * /bin/bash -lc 'source "$LIQUIDITY_BOT_ENV_FILE" && "$ROOT/scripts/liquidity-bot/run/run-daily-report.sh"'

# Run reserve weekly incident report every Monday at 00:30 (local time)
30 0 * * 1 /bin/bash -lc 'source "$LIQUIDITY_BOT_ENV_FILE" && "$ROOT/scripts/liquidity-bot/run/run-weekly-report.sh"'

# Run reserve monthly incident report on day 1 at 00:40 (local time)
40 0 1 * * /bin/bash -lc 'source "$LIQUIDITY_BOT_ENV_FILE" && "$ROOT/scripts/liquidity-bot/run/run-monthly-report.sh"'
