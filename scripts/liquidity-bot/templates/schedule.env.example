# Copy to schedule.env and adjust absolute paths for this machine.
#
# Example:
#   cp scripts/liquidity-bot/templates/schedule.env.example scripts/liquidity-bot/schedule.env
#   # then edit ROOT and derived paths.
#
# Optional when running wrappers:
#   LIQUIDITY_BOT_ENV_FILE=/absolute/path/to/schedule.env scripts/liquidity-bot/run/run-daily-report.sh

ROOT=/Users/yourname/workspace/private-repo/Bots/clawnet

# Core bot runtime
LIQUIDITY_BOT_CONFIG=$ROOT/scripts/liquidity-bot/config.local.json
LIQUIDITY_BOT_LOG_DIR=$ROOT/scripts/liquidity-bot/logs

# Report source + archive
LIQUIDITY_REPORT_SOURCE_LOG_DIR=$ROOT/scripts/liquidity-bot/logs
LIQUIDITY_REPORT_STORE_DIR=$ROOT/scripts/liquidity-bot/reports

# Report behavior
LIQUIDITY_REPORT_INCLUDE_DRY_RUN=false
LIQUIDITY_REPORT_PATTERN=reserve-compensation
LIQUIDITY_WEEK_START=monday

# Optional override directories
# LIQUIDITY_WEEKLY_REPORT_STORE_DIR=$ROOT/scripts/liquidity-bot/reports/weekly
# LIQUIDITY_MONTHLY_REPORT_STORE_DIR=$ROOT/scripts/liquidity-bot/reports/monthly

# Optional scheduler log dir (wrapper run logs)
# LIQUIDITY_REPORT_SCHEDULER_LOG_DIR=$ROOT/scripts/liquidity-bot/logs
