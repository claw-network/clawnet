{
  "name": "@claw-network/node",
  "version": "2026.3.6",
  "description": "ClawNet unified runtime — daemon, CLI, core protocol modules, and smart-contract toolchain",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/claw-network/clawnet.git",
    "directory": "packages/node"
  },
  "keywords": [
    "clawnet",
    "agent",
    "decentralized",
    "node",
    "daemon"
  ],
  "files": [
    "dist",
    "README.md",
    "artifacts",
    "contracts",
    "deployments",
    "hardhat.config.cjs",
    "scripts/contracts",
    "typechain-types"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "clawnet": "./dist/cli.js",
    "clawnetd": "./dist/daemon.js"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "package": "pnpm build && pkg . --output dist/pkg/clawnetd && node ../../scripts/rename-pkg.js",
    "test": "vitest run --passWithNoTests",
    "test:services": "vitest run --passWithNoTests test/services/",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "contracts:clean": "hardhat clean",
    "contracts:typechain": "typechain --target ethers-v6 --out-dir typechain-types $(find artifacts -name '*.json' -type f ! -name '*.dbg.json' ! -path '*/build-info/*' | sort)",
    "contracts:compile": "hardhat compile && pnpm contracts:typechain",
    "contracts:test": "pnpm contracts:compile && hardhat test $(find test/contracts -name '*.ts' -type f | sort)",
    "contracts:test:ed25519:besu": "pnpm contracts:compile && CLAWNET_BESU_PRECOMPILE_TEST=1 hardhat test test/contracts/Ed25519Verifier.besu.test.ts",
    "contracts:coverage": "hardhat coverage --testfiles 'test/contracts/**/*.ts'",
    "contracts:gas-report": "pnpm contracts:compile && REPORT_GAS=true hardhat test $(find test/contracts -name '*.ts' -type f | sort)",
    "contracts:deploy:local": "hardhat run scripts/contracts/deploy-helpers.ts --network hardhat",
    "contracts:deploy:testnet": "hardhat run scripts/contracts/deploy-all.ts --network clawnetTestnet",
    "contracts:deploy:testnet:bootstrap": "BOOTSTRAP_MINT=true hardhat run scripts/contracts/deploy-all.ts --network clawnetTestnet",
    "contracts:safe:deploy:testnet": "hardhat run scripts/contracts/deploy-safe-core.ts --network clawnetTestnet",
    "contracts:safe:create:testnet": "hardhat run scripts/contracts/create-safe-wallet.ts --network clawnetTestnet",
    "contracts:bootstrap:testnet": "hardhat run scripts/contracts/bootstrap-mint.ts --network clawnetTestnet",
    "contracts:slither": "slither .",
    "contracts:lint:sol": "solhint 'contracts/**/*.sol'",
    "lint": "eslint src test scripts/contracts --max-warnings=0"
  },
  "pkg": {
    "scripts": [
      "dist/daemon.js"
    ],
    "targets": [
      "node18-macos-x64",
      "node18-linux-x64",
      "node18-win-x64"
    ],
    "outputPath": "dist/pkg"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@claw-network/common": "workspace:*",
    "@chainsafe/libp2p-gossipsub": "^14.1.2",
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@libp2p/autonat": "^3.0.10",
    "@libp2p/bootstrap": "^12.0.11",
    "@libp2p/circuit-relay-v2": "^4.1.5",
    "@libp2p/crypto": "^5.1.13",
    "@libp2p/dcutr": "^3.0.10",
    "@libp2p/identify": "^4.0.10",
    "@libp2p/kad-dht": "^16.1.3",
    "@libp2p/mdns": "^12.0.11",
    "@libp2p/peer-id-factory": "^4.2.4",
    "@libp2p/ping": "^3.0.10",
    "@libp2p/tcp": "^11.0.10",
    "@multiformats/multiaddr": "^13.0.1",
    "@noble/curves": "^1.7.3",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.6.3",
    "@scure/base": "^1.1.9",
    "@scure/bip39": "^1.2.2",
    "better-sqlite3": "^12.2.0",
    "canonicalize": "^2.0.0",
    "ethers": "^6.16.0",
    "flatbuffers": "^24.3.25",
    "level": "^9.0.0",
    "libp2p": "^3.1.3",
    "multiformats": "^13.4.2",
    "otpauth": "^9.5.0",
    "prom-client": "^15.1.3",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@extism/extism": "^1.0.3",
    "@nomicfoundation/hardhat-ethers": "^3.1.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "5.2.0",
    "@openzeppelin/contracts-upgradeable": "5.2.0",
    "@openzeppelin/hardhat-upgrades": "^3.6.0",
    "@safe-global/safe-contracts": "^1.4.1",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/chai": "^4.3.20",
    "@types/ws": "^8.18.1",
    "ajv": "^8.18.0",
    "chai": "^4.5.0",
    "dotenv": "^16.4.0",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^2.2.0",
    "merkletreejs": "^0.6.0",
    "solhint": "^5.0.0",
    "solidity-coverage": "^0.8.0",
    "typechain": "^8.3.2"
  }
}
