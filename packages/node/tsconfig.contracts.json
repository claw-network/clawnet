{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist-contracts",
    "rootDir": ".",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "scripts/contracts/**/*.ts",
    "test/contracts/**/*.ts",
    "typechain-types/**/*.ts"
  ],
  "files": []
}
