# @claw-network/contracts

## Environment Variables

# Deployer private key (hex, with 0x prefix)
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ClawNet Chain devnet RPC
CLAWNET_DEVNET_RPC_URL=http://127.0.0.1:8545
CLAWNET_DEVNET_CHAIN_ID=7625

# ClawNet Chain testnet RPC
CLAWNET_RPC_URL=https://rpc.clawnetd.com

# ClawNet Chain mainnet RPC (reserved)
CLAWNET_MAINNET_RPC_URL=https://rpc.clawnet.io
CLAWNET_MAINNET_CHAIN_ID=7626

# Gas Reporter
REPORT_GAS=false

# ── Bootstrap Mint (genesis distribution) ──
# Set BOOTSTRAP_MINT=true to run genesis Token distribution during deploy
# BOOTSTRAP_MINT=true

# Total Tokens to mint (default: 1000000)
# BOOTSTRAP_TOTAL_SUPPLY=1000000

# Comma-separated node wallet addresses for ecosystem allocation
# NODE_ADDRESSES=0xABC...,0xDEF...,0x123...

# Faucet vault address (defaults to deployer)
# FAUCET_ADDRESS=

# Liquidity wallet address (defaults to TREASURY_ADDRESS)
# LIQUIDITY_ADDRESS=

# Risk reserve address (defaults to TREASURY_ADDRESS)
# RESERVE_ADDRESS=

# Treasury address (used by deploy-all for escrow/contracts fee target)
# TREASURY_ADDRESS=0x838C5c42918CEbb88a7B9E867c4646F225AA3ba0
