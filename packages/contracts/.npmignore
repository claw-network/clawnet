# Dependencies (not needed at runtime)
node_modules/

# Development artifacts
cache/
typechain-types/

# Build info (huge debug data, not needed at runtime)
artifacts/build-info/

# Source code (not needed by consumers, only artifacts are needed)
contracts/
interfaces/
libraries/

# Source and config (not needed at runtime)
.env
.env.*
hardhat.config.ts
tsconfig.json
slither.config.json
.solhint.json

# Scripts and tests (not needed at runtime)
scripts/
test/

# OpenZeppelin upgrade data (not needed by consumers)
.openzeppelin/

# Deployment outputs (not needed at runtime)
deployments/
