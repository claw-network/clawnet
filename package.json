{
  "name": "clawnet",
  "private": true,
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "scripts": {
    "prepare": "git config core.hooksPath scripts/hooks",
    "clawnet": "node packages/cli/dist/cli.js",
    "start": "node packages/node/dist/daemon.js",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "ci:local": "bash scripts/ci-local.sh",
    "test:partition": "node scripts/partition-test.mjs",
    "test:cluster": "bash scripts/cluster-test.sh",
    "test:cluster:integration": "bash scripts/cluster-test.sh integration",
    "test:cluster:partition": "bash scripts/cluster-test.sh partition",
    "ed25519:probe:testnet": "CLAWNET_BESU_TEST_NETWORK=clawnetTestnet node scripts/test-ed25519-precompile.mjs",
    "ed25519:test:testnet": "CLAWNET_BESU_TEST_NETWORK=clawnetTestnet CLAWNET_BESU_PRECOMPILE_TEST=1 pnpm contracts:test:ed25519:besu",
    "ed25519:probe:mainnet": "CLAWNET_ED25519_NETWORK=clawnetMainnet node scripts/test-ed25519-precompile.mjs",
    "ed25519:test:mainnet": "CLAWNET_ED25519_NETWORK=clawnetMainnet CLAWNET_BESU_PRECOMPILE_TEST=1 pnpm contracts:test:ed25519:besu",
    "contracts:compile": "pnpm --filter @claw-network/contracts compile",
    "contracts:test": "pnpm --filter @claw-network/contracts test",
    "contracts:test:ed25519:besu": "pnpm --filter @claw-network/contracts test:ed25519:besu",
    "contracts:coverage": "pnpm --filter @claw-network/contracts coverage",
    "publish:dry": "bash scripts/publish.sh",
    "publish:release": "bash scripts/publish.sh --release",
    "bump:patch": "node scripts/bump-version.mjs patch",
    "bump:minor": "node scripts/bump-version.mjs minor",
    "bump:major": "node scripts/bump-version.mjs major",
    "bump:dry": "node scripts/bump-version.mjs patch --dry",
    "format": "prettier --write .",
    "codegen:p2p": "flatc --ts --gen-mutable --gen-object-api -o packages/protocol/src/p2p/generated docs/implementation/p2p-spec.fbs",
    "liq:health": "node scripts/liquidity-bot/cli/health-check.mjs",
    "liq:fund": "node scripts/liquidity-bot/cli/fund-operators.mjs",
    "liq:publish": "node scripts/liquidity-bot/cli/publish-listings.mjs",
    "liq:trade": "node scripts/liquidity-bot/cli/trade-cycles.mjs",
    "liq:reconcile": "node scripts/liquidity-bot/cli/reconcile.mjs",
    "liq:reserve": "node scripts/liquidity-bot/cli/reserve-compensate.mjs",
    "liq:reserve:report": "node scripts/liquidity-bot/cli/reserve-daily-report.mjs",
    "liq:reserve:report:period": "node scripts/liquidity-bot/cli/reserve-period-report.mjs",
    "liq:reserve:report:week": "node scripts/liquidity-bot/cli/reserve-period-report.mjs --period week",
    "liq:reserve:report:month": "node scripts/liquidity-bot/cli/reserve-period-report.mjs --period month",
    "liq:run": "node scripts/liquidity-bot/cli/run-once.mjs",
    "secrets:keygen": "node scripts/secure-secrets.mjs gen-keypair",
    "secrets:manifest:init": "node scripts/secure-secrets.mjs refresh-manifest --manifest infra/testnet/scenarios/init/secret-files.txt --roots infra/testnet,infra/devnet",
    "secrets:encrypt:init": "pnpm secrets:manifest:init && node scripts/secure-secrets.mjs encrypt-manifest --manifest infra/testnet/scenarios/init/secret-files.txt --output infra/testnet/scenarios/init/secrets.bundle.enc",
    "secrets:decrypt": "node scripts/secure-secrets.mjs decrypt"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "@types/node": "^22.13.1",
    "@eslint/js": "^9.20.0",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.6.3",
    "@scure/base": "^1.2.6",
    "canonicalize": "^2.0.0",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.5.0",
    "pkg": "^5.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
