# Paths excluded from public repository sync (claw-network/clawnet).
# Used by .github/workflows/sync-public.yml to filter private content.
# Syntax: one path per line, glob patterns supported.
# Negation with ! to re-include a sub-path of an excluded parent.

# Internal documentation (except public API spec)
docs/*
!docs/api/

# Production infrastructure (except devnet for local development)
infra/testnet/
infra/mainnet/
infra/shared/
infra/besu/

# Deployment skills (contain server-specific procedures)
skills/

# Internal issues and temp files
issues/
temp/

# This file itself
.public-sync-ignore

# Private copilot instructions (replaced with public version during sync)
.github/copilot-instructions.md
